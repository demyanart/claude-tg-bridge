TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional. If unset, falls back to TELEGRAM_CHAT_ID (which equals user_id for 1:1 chats).
TELEGRAM_ALLOWED_USER_ID=

# tmux session that runs `claude`. Start manually: tmux new -s claude
TMUX_SESSION=claude
TMUX_TARGET=claude:0.0

# Output snapshot/flush tuning (ms)
TG_BRIDGE_POLL_MS=500
TG_BRIDGE_IDLE_MS=1500
